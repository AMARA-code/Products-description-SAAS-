# Copy to web/.env.local for Next.js and configure Expo public vars separately (see README).

# --- Web (Next.js) — place these in `web/.env.local` ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Public site URL (checkout redirects, emails)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OpenAI (required for PRO/AGENCY generation)
OPENAI_API_KEY=sk-REPLACE_WITH_OPENAI_KEY
OPENAI_MODEL=gpt-4o-mini

# PayFast
PAYFAST_MERCHANT_ID=REPLACE_PAYFAST_MERCHANT_ID
PAYFAST_MERCHANT_KEY=REPLACE_PAYFAST_MERCHANT_KEY
PAYFAST_PASSPHRASE=REPLACE_PAYFAST_PASSPHRASE
PAYFAST_PROCESS_URL=https://www.payfast.co.za/eng/process
PAYFAST_NOTIFY_URL=http://localhost:3000/api/webhooks/payfast
PAYFAST_RETURN_URL=http://localhost:3000/settings/billing
PAYFAST_CANCEL_URL=http://localhost:3000/pricing

# --- Expo mobile — use `mobile/.env` or EAS secrets ---
EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
